# Dev Dockerfile for Angular frontend — supports live reload via ng serve
# Used by docker-compose.yml (infra/docker-compose.yml)
FROM node:22-alpine AS dev

WORKDIR /app

# Install dependencies first for layer caching
COPY package.json package-lock.json* ./
RUN npm ci --prefer-offline || npm install

# Copy source (will be overridden by bind-mount in dev)
COPY . .

EXPOSE 4200

# Angular dev server — poll for file changes (needed in Docker)
CMD ["npx", "ng", "serve", "--host", "0.0.0.0", "--port", "4200", "--poll", "1000"]
