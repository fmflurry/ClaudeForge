# ─── Dev Dockerfile for Angular frontend (ng serve / HMR hot reload) ─────────
# Runs `ng serve` — Angular's native dev server with live reload and HMR.
# This is dev-only — for production use frontend/Dockerfile (multi-stage).
#
# Build context: repo root (required — frontend is an npm workspace; the
# authoritative package-lock.json lives at the repo root, not in frontend/).
#
# Usage (via docker compose): docker compose up web
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-alpine

WORKDIR /repo

# Copy workspace manifests for dependency install.
# Root package.json declares workspaces; root package-lock.json is the lockfile.
COPY package.json package-lock.json* ./
COPY frontend/package.json ./frontend/

# Install ALL dependencies (including devDeps) from the authoritative root lockfile.
# --legacy-peer-deps: angular-eslint@21 peer constraint on @angular/cli <22 is
# benign and pre-existing; same flag used in the production Dockerfile.
RUN npm ci --workspace=frontend --legacy-peer-deps

# Copy frontend source (overridden at runtime by the bind-mount in compose, but
# needed here so the image is self-contained if run without bind-mount).
COPY frontend/ ./frontend/

WORKDIR /repo/frontend

# ng serve default port
EXPOSE 4000

# Run Angular's native dev server using the "docker" Angular configuration, which
# sets host=0.0.0.0, port=4000, poll=500, allowedHosts=true, and routes /api
# through proxy.conf.docker.json to the api service (http://api:8080).
# allowedHosts=true is a typed boolean in angular.json — the former CLI flag
# `--allowed-hosts all` was invalid (string "all" was parsed as the positional
# [project] arg), causing "Invalid values: Argument: project, Given: all".
CMD ["npx", "ng", "serve", "--configuration", "docker"]
