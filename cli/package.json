{
  "name": "@claudeforge/claude-plugin-cli",
  "version": "0.1.0",
  "description": "Claude Code plugin marketplace CLI — install, publish, search, scaffold plugins",
  "main": "dist/index.js",
  "bin": {
    "claude-plugin": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --target node18",
    "build:watch": "tsup src/index.ts --format cjs --dts --target node18 --watch",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "semi": true,
    "trailingComma": "all"
  },
  "keywords": [
    "claude",
    "plugins",
    "cli",
    "marketplace"
  ],
  "author": "Florian Michel",
  "license": "PolyForm-Noncommercial-1.0.0",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "~6.0.2",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module"
}
