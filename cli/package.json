{
  "name": "@leclaudeforge/claude-plugin-cli",
  "version": "0.1.0",
  "description": "Command-line tool to install, update, remove and roll back Claude Code add-ons — hooks, skills, agents, plugins — locally or globally.",
  "main": "dist/index.cjs",
  "bin": {
    "claude-plugin": "dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "semi": true,
    "trailingComma": "all"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "plugin",
    "addon",
    "hooks",
    "skills",
    "agents"
  ],
  "author": "Florian Michel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmflurry/ClaudeForge.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/fmflurry/ClaudeForge/tree/main/cli#readme",
  "bugs": {
    "url": "https://github.com/fmflurry/ClaudeForge/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@claudeforge/plugin-template": "*",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "typescript-eslint": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "~6.0.2",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module"
}
