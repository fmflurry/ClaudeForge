{
  "name": "@claudeforge/plugin-template",
  "version": "0.1.0",
  "description": "Plugin scaffold generator for the ClaudeForge plugin marketplace — produces language-appropriate project templates (TypeScript, Python, Go, Rust)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "semi": true,
    "trailingComma": "all"
  },
  "keywords": [
    "claude",
    "plugins",
    "scaffold",
    "template",
    "marketplace"
  ],
  "author": "Florian Michel",
  "license": "PolyForm-Noncommercial-1.0.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "~6.0.2",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
