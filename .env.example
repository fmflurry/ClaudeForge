# ─── ClaudeForge Dev Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in the values for local development.
# NEVER commit the real .env file — it is git-ignored.

# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string for the .NET backend
# Format: Host=<host>;Port=<port>;Database=<db>;Username=<user>;Password=<password>
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=plugin_marketplace;Username=postgres;Password=devpassword

# ─── Package Storage ───────────────────────────────────────────────────────────
# Storage backend for plugin package artifacts
# Type: LocalFileSystem | OVHObjectStorage
PackageStorage__Type=LocalFileSystem

# Local filesystem path for dev (mapped as Docker bind-mount /packages)
PackageStorage__LocalPath=/packages

# OVH Object Storage (S3-compatible) — only required when PackageStorage__Type=OVHObjectStorage
# PackageStorage__S3Endpoint=https://s3.ovh.fr
# PackageStorage__BucketName=claude-plugins
# PackageStorage__AccessKey=<ovh-access-key>
# PackageStorage__SecretKey=<ovh-secret-key>

# ─── Frontend ──────────────────────────────────────────────────────────────────
# Base URL for the Angular frontend to reach the backend API
# Dev: http://localhost:5000/api/v1  |  Prod: https://api.claudeforge.dev/api/v1
API_BASE_URL=http://localhost:5000/api/v1

# ─── CLI ───────────────────────────────────────────────────────────────────────
# API URL used by the CLI when no local config exists
# Overrides ~/.claude-plugins/config.json api-url
CLAUDE_PLUGINS_API_URL=http://localhost:5000/api/v1

# ─── PostgreSQL (docker-compose) ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=plugin_marketplace

# ─── Feature Flags ─────────────────────────────────────────────────────────────
# Set to true to enable Qdrant semantic search adapter (requires --profile semantic)
Features__QdrantEnabled=false

# Raw telemetry event retention in days (default: 90)
Features__TelemetryRetention=90

# Require authenticated user to upload/publish plugins (Phase 3 breaking gate).
# false = anonymous upload allowed (Phase 1/2); true = auth enforced (Phase 3).
Features__RequireAuthForUpload=false

# ─── OIDC — Google ─────────────────────────────────────────────────────────────
# OAuth 2.0 credentials from Google Cloud Console.
# See docs/auth-provider-setup.md for step-by-step setup instructions.
OIDC__GOOGLE__CLIENTID=<your-google-client-id>.apps.googleusercontent.com
OIDC__GOOGLE__CLIENTSECRET=<your-google-client-secret>
# Loopback/SPA callback URL registered in Google Cloud Console.
# Dev:  http://localhost:5010/auth/callback
# Prod: https://api.claudeforge.dev/auth/callback
OIDC__GOOGLE__REDIRECTURI=http://localhost:5010/auth/callback

# ─── OIDC — Microsoft ─────────────────────────────────────────────────────────
# OAuth 2.0 credentials from Azure Entra (formerly Azure AD) app registration.
# See docs/auth-provider-setup.md for step-by-step setup instructions.
OIDC__MICROSOFT__CLIENTID=<your-azure-app-client-id>
OIDC__MICROSOFT__CLIENTSECRET=<your-azure-client-secret>
# Tenant: 'common' (multi-tenant + personal) | specific tenant UUID (enterprise-only)
OIDC__MICROSOFT__TENANT=common
# Loopback/SPA callback URL registered in Azure Entra.
# Dev:  http://localhost:5010/auth/callback
# Prod: https://api.claudeforge.dev/auth/callback
OIDC__MICROSOFT__REDIRECTURI=http://localhost:5010/auth/callback

# ─── OIDC — Shared ────────────────────────────────────────────────────────────
# Comma-separated list of enabled providers. Only providers listed here are
# resolvable; requests for others are rejected with HTTP 400.
OIDC__ENABLEDPROVIDERS=google,microsoft

# Allowed loopback redirect prefix for CLI PKCE login (RFC 8252).
# The backend validates that CLI redirect_uri starts with this value.
# Do NOT include a port — the CLI chooses a random port at runtime.
OIDC__ALLOWEDLOOPBACKREDIRECT=http://127.0.0.1

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Issuer and audience embedded in every issued access token (iss / aud claims).
# Must match exactly in backend validation config.
JWT__ISSUER=https://api.claudeforge.dev
JWT__AUDIENCE=claudeforge-spa-cli

# RS256 access token lifetime in minutes (default: 15).
JWT__ACCESSTOKENMINUTES=15

# Opaque refresh token lifetime in days (default: 30).
JWT__REFRESHTOKENDAYS=30

# RS256 private key (PEM format) used to sign access tokens.
# NEVER paste the real private key here. In dev, this env var is populated from
# the Docker secret/file mount (see infra/docker-compose.yml secrets section).
# Generate a key pair: see docs/auth-provider-setup.md — "JWT Key Generation".
# In production this must be provided via a secret manager or secret file mount;
# the value below is a placeholder that will be rejected at startup.
JWT__SIGNINGKEY__PRIVATEPEM=<path-or-value-provided-via-secret-mount — do-not-set-inline>

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
# Used to send organization invitation emails via IInvitationEmailPort.
# The concrete provider is SMTP; swap adapter for Sendgrid/Postmark in the future.
EMAIL__SMTPHOST=smtp.example.com
EMAIL__SMTPPORT=587
EMAIL__SMTPUSER=<smtp-username>
EMAIL__SMTPPASSWORD=<smtp-password>
EMAIL__FROM=noreply@claudeforge.dev
